#!/usr/bin/env bash
# shellcheck disable=SC1091

set -euo pipefail

_brew() {
  local brew_cmd="{{ includeTemplate "global/helpers/getData" (dict
  "path" (list "dependencies" "brew" "settings" "binpath")
  "defaults" "${HOMEBREW_PREFIX:-}/bin"
  "context" .
) | mustFromJson }}/brew"

  if command -v brew >/dev/null 2>&1; then
    brew "$@"        ## Use brew from PATH if available
  elif [ -f "$brew_cmd" ]; then
    "$brew_cmd" "$@" ## Use brew from binpath if available
  else
    error 'Error: brew command not found (%s)\n' "$brew_cmd"
    return 99
  fi
}

_brew_activate() {
  local shell_name="${1:-bash}"
  eval "$(_brew shellenv "$shell_name")"
}
