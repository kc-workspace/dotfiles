{{- includeTemplate "featureFlags/helpers/mustEnable" (dict
  "flag" "ai::copilot:enable"
  "context" $
) -}}
{
  "version": 1,
  "hooks": {
    "PreToolUse": [
      {
        "type": "command",
        "command": "mise exec pipx:serena-agent@latest -- serena-hooks remind --client=vscode"
      }
    ],
    "SessionStart": [
      {
        "type": "command",
        "command": "mise exec pipx:serena-agent@latest -- serena-hooks activate --client=vscode"
      }
    ],
    "Stop": [
      {
        "type": "command",
        "command": "mise exec pipx:serena-agent@latest -- serena-hooks cleanup --client=vscode"
      }
    ]
  }
}
