## $HOME/.config/chezmoi/chezmoi.yaml

encryption: age
age:
  identity: "~/.config/chezmoi/key.txt"
  recipient: ""

sourceDir: "~/.local/share/chezmoi"
destDir: "~"

## https://www.chezmoi.io/user-guide/daily-operations/#automatically-commit-and-push-changes-to-your-repo
git:
  autoAdd: true
  autoCommit: false
  autoPush: false
  ## relative to chezmoiroot path
  commitMessageTemplateFile: ".chezmoitemplates/commit.tmpl"

progress: true

edit:
  apply: true
  watch: true
  command: "code-insiders"
  args: ["--wait"]

update:
  apply: true

onepassword:
  mode: "{{ if or (env "GITHUB_ACTIONS") (env "DOCKER") }}service{{ else }}account{{ end }}"
  prompt: true

data:
  {{- $data := mustMergeOverwrite $ }}
  {{- range glob (joinPath .chezmoi.sourceDir ".chezmoidata" "**" "*.yaml") }}
    {{- $data = mustMergeOverwrite $data
      (include . | fromYaml)
    }}
  {{- end }}

  {{- $global := dig "_global" dict . }}
  {{- $defaultProfile := includeTemplate "global/variables/profile" . }}
  {{- $profiles := dig "_constants" "profiles" list $data }}
  {{- $profile := promptChoiceOnce $global "profile" "Profile" $profiles $defaultProfile }}
  {{- with $profile }}
    {{- $_ := set $global "profile" . }}
  {{- end }}
  {{- $defaultPlatform := includeTemplate "global/variables/platform" . }}
  {{- $platforms := dig "_constants" "platforms" list $data }}
  {{- $platform := promptChoiceOnce $global "platform" "Platform" $platforms $defaultPlatform }}
  {{- with $platform }}
    {{- $_ := set $global "platform" . }}
  {{- end }}
  {{- $data = mustMergeOverwrite $data (dict "_global" $global) }}

  _global: {{- $global | toYaml | nindent 4 }}
  _overrides:
      {{- $settings := dig "_overrides" "settings" dict . }}
    settings:
      {{- $age := includeTemplate "global/helpers/getData" (dict
        "path" (list "settings" "age")
        "defaults" false
        "context" $data
      ) | mustFromJson }}
      age: {{ ternary true (promptBool "Enable age" $age) $age }}

      {{- $onepassword := includeTemplate "global/helpers/getData" (dict
        "path" (list "settings" "onepassword")
        "defaults" false
        "context" $data
      ) | mustFromJson }}
      onepassword: {{ ternary true (promptBool "Enable 1Password" $onepassword) $onepassword }}

      {{- $flags := includeTemplate "featureFlags/helpers/list" $data | mustFromJson }}
      ## When is not empty list, this will overrides _base and profile/platform specific
      featureFlags: {{- promptMultichoiceOnce $settings "featureFlags" "Feature Flags" $flags list | toYaml | nindent 8 }}
