## $HOME/.config/chezmoi/chezmoi.yaml

encryption: age
age:
  identity: "~/.config/chezmoi/key.txt"
  recipient: "age12z9uwglawqmejczved5k6969ueej6y0r3hjnmhnp968z5nxlfdkscdlpg0"

sourceDir: "~/.local/share/chezmoi"
destDir: "~"

## https://www.chezmoi.io/user-guide/daily-operations/#automatically-commit-and-push-changes-to-your-repo
git:
  autoAdd: true
  autoCommit: false
  autoPush: false
  ## relative to chezmoiroot path
  commitMessageTemplateFile: ".chezmoitemplates/commit.tmpl"

progress: true

edit:
  apply: true
  watch: true
  command: "code-insiders"
  args: ["--wait"]

update:
  apply: true

onepassword:
  mode: "{{ if or (env "GITHUB_ACTIONS") (env "DOCKER") }}service{{ else }}account{{ end }}"
  prompt: true

data:
  _global:
    {{- $global := dig "_global" dict . -}}
    {{- $defaultProfile := includeTemplate "global/variables/profile" . -}}
    {{- $profiles := list "actions" "docker" "machine" }}
    profile: {{ promptChoiceOnce $global "profile" "Profile" $profiles $defaultProfile }}
    {{- $defaultPlatform := includeTemplate "global/variables/platform" . }}
    platform: {{ promptStringOnce $global "platform" "Platform" $defaultPlatform }}

  _base:
    settings:
      {{- $settings := dig "_base" "settings" dict . -}}
      {{- $flags := includeTemplate "global/variables/featureFlags" . | mustFromJson }}
      featureFlags: {{- promptMultichoiceOnce $settings "featureFlags" "Feature Flags" $flags list | toYaml | nindent 6 }}
