#!/usr/bin/env sh

printf '>> Starting... %s\n' "setup-preferences.sh"

set -e

{{- range dig "preferences" .global.profile .global.os list . }}
{{- $beforeCmd := dig "hooks" "before" "" . }}
{{- $afterCmd := dig "hooks" "after" "" . }}

{{- if ne $beforeCmd "" }}

{{ $beforeCmd }}

{{- end }}
{{- $cmd := .command }}
{{- if eq $cmd "defaults" }}
{{- $ns := .namespace }}

{{- printf "\n" }}
{{- range .settings }}

{{- $options := dig "options" list . | join " " }}

{{- $valueType := printf "-%s" (kindOf .value) }}
{{- $value := (printf "\"%v\"" .value) }}
{{- if or (kindIs "uint" .value) (kindIs "uint32" .value) (kindIs "uint64" .value) -}}
  {{- $valueType = "-int" }}
{{- else if or (kindIs "int" .value) (kindIs "int32" .value) (kindIs "int64" .value) -}}
  {{- $valueType = "-int" }}
{{- else if or (kindIs "float32" .value) (kindIs "float64" .value) -}}
  {{- $valueType = "-float" }}
{{- else if kindIs "slice" .value -}}
  {{- $values := list }}
  {{- range .value }}
    {{- $values = append $values (printf "\"%v\"" .) }}
  {{- end }}
  {{- $valueType = "-array" }}
  {{- $value = join " " $values }}
{{- end }}

{{- if ne (dig "type" "" .) "" -}}
  {{- $valueType = printf "-%s" (dig "type" "" .) }}
{{- end }}

{{- $args := list }}
{{- if eq .value nil }}
  {{- $args = list $cmd $options "delete" $ns .key }}
{{- else }}
  {{- $args = list $cmd $options "write" $ns .key $valueType $value }}
{{- end }}
{{ compact $args | join " " }}

{{- end }}

{{- else if eq $cmd "dockutil" }}

{{ template "shellVars/brew.tmpl" }}
dockutil_cmd="$brew_bin/dockutil"
if ! [ -f "$dockutil_cmd" ]; then
  "$brew_cmd" install dockutil
fi

"$dockutil_cmd" --remove all --no-restart
{{ range .apps }}
"$dockutil_cmd" --{{ dig "action" "add" . }} "{{ .name }}" \
  --section apps --no-restart {{- with dig "args" list . }} {{ join " " . }}{{- end }}
{{- end }}

killall Dock
{{ range .others }}
"$dockutil_cmd" --{{ dig "action" "add" . }} "{{ .name }}" \
  --section others --no-restart {{- with dig "args" list . }} {{ join " " . }}{{- end }}
{{- end }}

"$brew_cmd" uninstall dockutil
unset brew_bin brew_cmd dockutil_cmd

{{- end }}

{{- if ne $afterCmd "" }}

{{ $afterCmd }}

{{- end }}

{{- end }}
