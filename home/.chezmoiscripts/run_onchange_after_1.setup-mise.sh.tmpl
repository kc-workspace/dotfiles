#!/usr/bin/env sh

{{- $platform := "machine" }}
{{- if eq (env "GITHUB_ACTIONS") "true" }}
  {{- $platform = "actions" }}
{{- end }}
{{- if eq (env "DOCKER") "true" }}
  {{- $platform = "docker" }}
{{- end }}

{{- $os := .chezmoi.os }}
{{- with .chezmoi.osRelease }}
  {{- $os = printf "%s/%s" $os .id -}}
{{- end }}

printf '>> Starting... %s\n' "setup-mise.sh"

set -e

{{- $deps := dig "dependencies" $platform $os "" $ }}
{{- with $deps }}
{{- if dig "mise" "_settings" "install" true . }}

printf '>>> Checking... %s\n' "mise"
export MISE_INSTALL_PATH="$HOME/.local/bin/mise" ## Use in mise.run script
if ! command -v mise >/dev/null; then
  tmp="$(mktemp)"

  printf '>>> Installing... %s (%s)\n' "mise" "$tmp"
  curl -fsSLo "$tmp" https://mise.run
  sh "$tmp"
  rm "$tmp"

  unset tmp
fi

"$MISE_INSTALL_PATH" --version

set -x

{{- if dig "mise" "_settings" "upgrade" true . }}
"$MISE_INSTALL_PATH" self-update --yes
{{- end }}
{{- $tools := (dig "mise" "tools" "" .) }}

{{- with $tools }}
{{- if and (kindIs "string" .) (eq . "ALL") }}
"$MISE_INSTALL_PATH" install --yes
{{- else if kindIs "slice" . }}
"$MISE_INSTALL_PATH" install --yes {{- range . }} {{ . }}{{- end }}
{{- end }}
{{- end }}
set +x

unset MISE_INSTALL_PATH

{{- end }}{{- end }}
