#!/usr/bin/env sh

{{- $platform := "machine" }}
{{- if eq (env "GITHUB_ACTIONS") "true" }}
  {{- $platform = "actions" }}
{{- end }}
{{- if eq (env "DOCKER") "true" }}
  {{- $platform = "docker" }}
{{- end }}

{{- $os := .chezmoi.os }}
{{- with .chezmoi.osRelease }}
  {{- $os = printf "%s/%s" $os .id -}}
{{- end }}

printf '>> Starting... %s\n' "prerequisite.sh"

set -e

{{- $deps := dig "dependencies" $platform $os "" $ }}
{{- with $deps }}
{{- if dig "apt" "packages" list . }}

printf '>>> Checking... %s\n' "apt"
if ! command -v apt >/dev/null; then
  echo 'Missing apt command' >&2
  exit 1
fi

{{- end }}
{{- if dig "apk" "packages" list . }}

printf '>>> Checking... %s\n' "apk"
if ! command -v apk >/dev/null; then
  echo 'Missing apk command' >&2
  exit 1
fi

{{- end }}{{- end }}
