#!/usr/bin/env sh

printf '>> Starting... %s\n' "setup-preferences.sh"

set -e

{{- range dig "preferences" .global.profile .global.os list . }}
{{- $beforeCmd := dig "hooks" "before" "" . }}
{{- $afterCmd := dig "hooks" "after" "" . }}

{{- if ne $beforeCmd "" }}

{{ $beforeCmd }}

{{- end }}
{{- $cmd := .command }}
{{- if eq $cmd "dockutil" }}

{{ template "shellVars/brew.tmpl" }}
dockutil_cmd="$brew_bin/dockutil"
if ! [ -f "$dockutil_cmd" ]; then
  "$brew_cmd" install dockutil
fi

"$dockutil_cmd" --remove all --no-restart
{{ range .apps }}
"$dockutil_cmd" --{{ dig "action" "add" . }} "{{ .name }}" \
  --section apps --no-restart {{- with dig "args" list . }} {{ join " " . }}{{- end }}
{{- end }}

killall Dock
{{ range .others }}
"$dockutil_cmd" --{{ dig "action" "add" . }} "{{ .name }}" \
  --section others --no-restart {{- with dig "args" list . }} {{ join " " . }}{{- end }}
{{- end }}

"$brew_cmd" uninstall dockutil
unset brew_bin brew_cmd dockutil_cmd

{{- end }}

{{- if ne $afterCmd "" }}

{{ $afterCmd }}

{{- end }}

{{- end }}
