{{- $apt := includeTemplate "global/helpers/getData" (dict
  "path" (list "dependencies" "apt")
  "defaults" dict
  "context" .
) | mustFromJson }}

{{- $packages := dig "packages" list $apt -}}
{{- $autoupdate := dig "settings" "autoupdate" true $apt -}}
{{- $autoupgrade := dig "settings" "autoupgrade" true $apt -}}
{{- $autoclean := dig "settings" "autoclean" true $apt -}}
{{- if or $packages $autoupdate $autoupgrade $autoclean -}}
#!/usr/bin/env sh

set -eu

printf '>> Starting... %s\n' "dependencies-apt.sh"

apt_cmd="{{ dig "settings" "command" "apt" $apt }}"

printf '>>> Checking... %s\n' "$apt_cmd"
if ! command -v "$apt_cmd" >/dev/null; then
  printf '>>> Error: %s command not found\n' "$apt_cmd"
  exit 1
fi

run_as_root() {
  if [ "$(id -u)" -eq 0 ]; then
    printf '>>> $ %s\n' "$*"
    "$@"
  elif command -v sudo >/dev/null; then
    printf '>>> $ %s %s\n' "sudo $*"
    sudo "$@"
  else
    printf '>>> Error: %s\n' "sudo is required when not running as root"
    exit 1
  fi
}

{{- if $autoupdate }}
run_as_root "$apt_cmd" update --quiet
{{- end }}

{{- if $packages }}
run_as_root "$apt_cmd" install --yes --quiet
{{- range $packages }} \
  {{- . | quote | nindent 2 -}}
{{ end }}
{{- end }}

{{- if $autoupgrade }}
run_as_root "$apt_cmd" upgrade --yes --quiet
{{- end }}

{{- if $autoclean }}
run_as_root "$apt_cmd" clean --quiet
{{- end }}

unset apt_cmd
unset -f run_as_root
{{- end }}